                android:text=" "
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textColorLink="#FDFDFD"
                android:textSize="96dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#837C7C"
                app:strokeColor="#101010"
                app:strokeWidth="10dp" />

