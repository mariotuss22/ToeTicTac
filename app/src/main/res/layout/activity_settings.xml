<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".settingsActivity">

    <SeekBar
        android:id="@+id/boardSize_Slider"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="288dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.505"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="250dp"
        android:layout_height="75dp"
        android:layout_marginStart="80dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="81dp"
        android:text="Board Size"
        android:textAlignment="center"
        android:textSize="50sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/preview_board"
        android:layout_width="350dp"
        android:layout_height="300dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/boardSize_Slider"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/previewButton0"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="O"
                android:textSize="50sp" />

            <Button
                android:id="@+id/previewButton1"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="O"
                android:textSize="50sp" />

            <Button
                android:id="@+id/previewButton2"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="X"
                android:textSize="50sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/previewButton3"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="X"
                android:textSize="50sp" />

            <Button
                android:id="@+id/previewButton4"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="X"
                android:textSize="50sp" />

            <Button
                android:id="@+id/previewButton5"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="O"
                android:textSize="50sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/previewButton6"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="O"
                android:textSize="50sp" />

            <Button
                android:id="@+id/previewButton7"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DRAW"
                android:textSize="20sp" />

            <Button
                android:id="@+id/previewButton8"
                style="@style/Widget.AppCompat.Button"
                android:layout_width="116dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="X"
                android:textSize="50sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="380dp"
        android:layout_height="250dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="15dp"
        android:layout_marginBottom="30dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Switch
            android:id="@+id/inf_Switch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Infinite Mode"
            android:textSize="25sp" />

        <Switch
            android:id="@+id/gamble_Switch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Gambling Mode"
            android:textSize="25sp" />

        <Switch
            android:id="@+id/shuffle_Switch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Shuffle Mode"
            android:textSize="25sp" />

        <Switch
            android:id="@+id/single_Switch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Single Player Mode"
            android:textSize="25sp" />

        <Switch
            android:id="@+id/ultimate_Switch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Ultimate TTT"
            android:textSize="25sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>